# Database connection string (PostgreSQL)
# For local: postgresql://user@localhost:5432/opsflow
# For Neon/Supabase: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/opsflow"

# JWT secret for authentication (use a strong random string in production)
JWT_SECRET="your-secret-key-here"

# OpenAI API key (optional - AI features will use fallback without it)
OPENAI_API_KEY=""

# OpenAI model (optional - defaults to gpt-4o-mini)
OPENAI_MODEL="gpt-4o-mini"
